# school-registry 로컬 개발 환경변수

# AWS
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_DEFAULT_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000

# 런타임
REGION=us-east-1
ENVIRONMENT=local

# DynamoDB
SCHOOLS_TABLE=school-buddy-schools-local
NOTICES_TABLE=school-buddy-notices-local
CHILDREN_TABLE=school-buddy-children-local
