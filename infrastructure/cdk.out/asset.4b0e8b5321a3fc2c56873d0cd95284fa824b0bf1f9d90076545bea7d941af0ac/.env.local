# notice-processor 로컬 개발 환경변수
# ⚠️ Bedrock은 로컬 에뮬레이터 없음 → 실제 AWS 자격증명 필요

# AWS
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_DEFAULT_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000
# LocalStack SQS/SNS용
AWS_ENDPOINT_URL=http://localhost:4566

# 런타임
REGION=us-east-1
ENVIRONMENT=local

# DynamoDB
NOTICES_TABLE=school-buddy-notices-local
TRANSLATION_CACHE_TABLE=school-buddy-translation-cache-local

# Bedrock (실제 AWS 자격증명 필요 — 로컬 에뮬레이터 없음)
# AWS_ACCESS_KEY_ID=<your-aws-key>
# AWS_SECRET_ACCESS_KEY=<your-aws-secret>
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
MAX_TOKENS_SUMMARY=500
MAX_TOKENS_TRANSLATION=800

# SQS
NOTICE_QUEUE_URL=http://localhost:4566/000000000000/school-buddy-notice-queue-local
