# kb-sync 로컬 개발 환경변수

# AWS (실제 자격증명 필요 — Bedrock KB는 로컬 에뮬레이터 없음)
# AWS_ACCESS_KEY_ID=<your-aws-key>
# AWS_SECRET_ACCESS_KEY=<your-aws-secret>
AWS_DEFAULT_REGION=us-east-1

# 런타임
REGION=us-east-1
ENVIRONMENT=local

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=<deployed-kb-id>
DATA_SOURCE_ID=<deployed-datasource-id>
