# user-manager 로컬 개발 환경변수

# AWS
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_DEFAULT_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000

# 런타임
REGION=us-east-1
ENVIRONMENT=local

# DynamoDB
USERS_TABLE=school-buddy-users-local
CHILDREN_TABLE=school-buddy-children-local

# Cognito (로컬 테스트 시 JWT 검증 건너뜀)
USER_POOL_ID=local-mock-user-pool
USER_POOL_CLIENT_ID=local-mock-client-id
